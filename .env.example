# --- ERP FIREBASE CONFIG (Google Auth / Google Sheets) ---
# Diperlukan untuk Google Sign-In dan akses Google Sheets API
# Salin dari firebase-applet-config.json saat setup
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# --- WEB STORE FIRESTORE CONFIG ---
# Project Firestore yang SAMA dengan aplikasi Web Store
# Diperlukan untuk sync ERP ↔ Web Store
VITE_WEBSTORE_API_KEY=your-webstore-api-key
VITE_WEBSTORE_PROJECT_ID=your-webstore-project-id
VITE_WEBSTORE_APP_ID=your-webstore-app-id
VITE_WEBSTORE_AUTH_DOMAIN=your-webstore.firebaseapp.com
VITE_WEBSTORE_DATABASE_ID=your-database-id
VITE_WEBSTORE_STORAGE_BUCKET=your-webstore.firebasestorage.app
VITE_WEBSTORE_MESSAGING_SENDER_ID=your-webstore-sender-id

# --- WEB STORE URL ---
# URL tempat web store di-deploy (untuk tombol "Kunjungi Webstore")
# Jika tidak diisi, akan muncul prompt untuk memasukkan URL manual
VITE_WEBSTORE_URL=https://near-bakery-store.vercel.app

# --- PRINTER RELAY URL ---
# URL relay server printer thermal (local). Default: http://localhost:3001
# Jalankan start-printer.bat untuk memulai relay server.
# Atau set port berbeda: VITE_PRINTER_RELAY_URL=http://localhost:3005
VITE_PRINTER_RELAY_URL=http://localhost:3001

# --- GEMINI AI ---
# Diisi otomatis oleh AI Studio runtime atau Vercel environment
# Juga digunakan sebagai API Key untuk endpoint /api/*
GEMINI_API_KEY=your-gemini-api-key

# --- SMTP CONFIGURATION (untuk Backup Email) ---
# SMTP credentials disimpan di server (environment), BUKAN dari client!
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
