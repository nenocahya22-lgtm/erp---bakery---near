rules_version = '2';

// ──────────────────────────────────────────────────────────────
// Firestore Security Rules — Near Bakery & Co. ERP + Web Store
// ──────────────────────────────────────────────────────────────
// KEAMANAN:
// - Setiap collection memiliki aturan read/write spesifik
// - ERP menggunakan Anonymous Auth (request.auth != null)
// - TIDAK ADA wildcard {document=**} — setiap path didefinisikan eksplisit
// - Collection ERP (erp_*) hanya bisa ditulis oleh ERP (authenticated)
// - Collection Web Store (orders, chats) dibedakan read vs write
// - Orders: customer bisa create, ERP bisa read + update
// - Storage untuk payment proofs hanya authenticated
// ──────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── FUNGSI VALIDASI ──
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwnerOrAdmin() {
      return isAuthenticated();
      // Di masa depan: tambahkan validasi UID spesifik
      // return request.auth.uid in ['erp-admin-uid', ...];
    }

    // ════════════════════════════════════════════════════════════
    // ERP COLLECTIONS — Hanya untuk aplikasi ERP
    // ════════════════════════════════════════════════════════════

    // Web Store Config — baca/tulis hanya oleh ERP (authenticated)
    match /webstore_config/{cabangId} {
      allow read: if isAuthenticated();
      allow write: if isOwnerOrAdmin();
      allow create: if isOwnerOrAdmin();
      allow delete: if isOwnerOrAdmin();
    }

    // Products — ERP publish, Web Store baca
    match /products/{productId} {
      allow read: if true;  // Public read — Web Store customer bisa lihat produk
      allow write: if isOwnerOrAdmin();
      allow create: if isOwnerOrAdmin();
      allow delete: if isOwnerOrAdmin();
    }

    // Categories — ERP atur, Web Store baca
    match /categories/{cabangId} {
      allow read: if true;  // Public read — Web Store customer lihat kategori
      allow write: if isOwnerOrAdmin();
      allow create: if isOwnerOrAdmin();
      allow delete: if isOwnerOrAdmin();
    }

    // ERP Data (erp_*) — hanya ERP
    match /erp_bahan_baku/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /erp_products/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /erp_detail_resep/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /erp_cabang/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /erp_surat_orders/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /erp_waste_logs/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /erp_writeoff_logs/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /erp_rd_experiments/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /erp_toppings/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /erp_cabang_stok/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /erp_branch_transactions/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ERP Notifications
    match /erp_notifications/{notifId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      allow create: if true;  // Web Store bisa kirim notifikasi
      allow delete: if isOwnerOrAdmin();
    }

    // Cabang Subdomains
    match /cabang_subdomains/{subdomain} {
      allow read: if isAuthenticated();
      allow write: if isOwnerOrAdmin();
    }

    // ════════════════════════════════════════════════════════════
    // WEB STORE COLLECTIONS — dibedakan read vs write
    // ════════════════════════════════════════════════════════════

    // ── FUNGSI VALIDASI ORDERS ──
    function isValidOrder() {
      return (
        request.resource.data is map &&
        request.resource.data.keys().hasAll(['totalAmount', 'items', 'userName']) &&
        request.resource.data.totalAmount is number &&
        request.resource.data.totalAmount > 0 &&
        request.resource.data.totalAmount <= 500000000 &&  // Maks Rp 500 juta per order
        request.resource.data.items is list &&
        request.resource.data.items.size() > 0 &&
        request.resource.data.items.size() <= 50 &&        // Maks 50 item per order
        request.resource.data.userName is string &&
        request.resource.data.userName.size() > 0 &&
        request.resource.data.userName.size() <= 100 &&
        request.resource.data.keys().hasAll(['paymentMethod']) &&
        request.resource.data.paymentMethod is string
      );
    }

    // Orders — Customer bisa create (order), ERP bisa read + update status
    match /orders/{orderId} {
      allow read: if isAuthenticated();     // ERP lihat semua order
      allow create: if isValidOrder();       // Customer bisa order tanpa login, dengan validasi
      allow update: if isAuthenticated();   // ERP update status
      allow delete: if false;               // Tidak ada yang bisa hapus order
    }

    // ── FUNGSI VALIDASI CHATS ──
    function isValidChat() {
      return (
        request.resource.data is map &&
        request.resource.data.keys().hasAll(['buyerName', 'lastMessage']) &&
        request.resource.data.buyerName is string &&
        request.resource.data.buyerName.size() > 0 &&
        request.resource.data.buyerName.size() <= 100 &&
        request.resource.data.lastMessage is string &&
        request.resource.data.lastMessage.size() > 0 &&
        request.resource.data.lastMessage.size() <= 2000 &&
        request.resource.data.keys().hasAll(['buyerEmail']) &&
        request.resource.data.buyerEmail is string &&
        request.resource.data.buyerEmail.size() <= 320
      );
    }

    // Chats — Customer buat, ERP baca + balas
    match /chats/{chatId} {
      allow read: if isAuthenticated();     // ERP lihat chat
      allow create: if isValidChat();        // Customer mulai chat tanpa login, dengan validasi
      allow update: if isAuthenticated();   // ERP balas chat
      allow delete: if false;
    }

    // ════════════════════════════════════════════════════════════
    // FALLBACK — path yang tidak tercakup di atas
    // ════════════════════════════════════════════════════════════
    // Tidak ada wildcard {document=**} — setiap path harus didefinisikan
    // Jika ada collection baru, tambahkan aturan spesifik di atas.
    // JANGAN tambahkan wildcard — demi keamanan.
  }
}
