rules_version = '2';

// ──────────────────────────────────────────────────────────────
// Firestore Security Rules — Near Bakery & Co. ERP + Web Store
// ──────────────────────────────────────────────────────────────
// KEAMANAN:
// - Setiap collection memiliki aturan read/write spesifik
// - ERP menggunakan Anonymous Auth (request.auth != null)
// - Web Store menggunakan Firebase Auth (anonim/email)
// - TIDAK ADA wildcard {document=**} — setiap path didefinisikan eksplisit
// - Collection ERP (erp_*) hanya bisa ditulis oleh ERP (authenticated)
// - Collection Web Store (orders, chats) dibedakan read vs write
// - Orders: customer bisa create, ERP bisa read + update
// - Storage untuk payment proofs hanya authenticated
// ──────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── FUNGSI VALIDASI GLOBAL ──
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwnerOrAdmin() {
      return isAuthenticated();
      // Di masa depan: tambahkan validasi UID spesifik
      // return request.auth.uid in ['erp-admin-uid', ...];
    }

    function isMerchant() {
      return isAuthenticated() && (
        request.auth.token.get('email', '') == 'nenocahya22@gmail.com' ||
        request.auth.token.get('email', '') == 'seller@webstore.com' ||
        exists(/databases/$(database)/documents/merchants/$(request.auth.uid))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ── FUNGSI VALIDASI ORDERS ──
    function isValidOrder() {
      return (
        incoming() is map &&
        incoming().keys().hasAll(['id', 'userId', 'userName', 'userEmail', 'items', 'totalAmount', 'status', 'shippingAddress', 'paymentMethod', 'paymentStatus']) &&
        incoming().id is string && incoming().id.size() <= 128 &&
        incoming().userId is string && incoming().userId.size() <= 128 &&
        incoming().userName is string && incoming().userName.size() > 0 && incoming().userName.size() <= 100 &&
        incoming().userEmail is string && incoming().userEmail.size() <= 100 &&
        incoming().items is list && incoming().items.size() > 0 && incoming().items.size() <= 50 &&
        (incoming().totalAmount is int || incoming().totalAmount is float) && incoming().totalAmount > 0 && incoming().totalAmount <= 500000000 &&
        incoming().status is string && incoming().status.size() <= 50 &&
        incoming().shippingAddress is map &&
        incoming().paymentMethod is string && incoming().paymentMethod.size() <= 50 &&
        incoming().paymentStatus is string && incoming().paymentStatus.size() <= 50
      );
    }

    // ── FUNGSI VALIDASI CHATS ──
    function isValidChat() {
      return (
        incoming() is map &&
        incoming().keys().hasAll(['buyerName', 'lastMessage']) &&
        incoming().buyerName is string &&
        incoming().buyerName.size() > 0 &&
        incoming().buyerName.size() <= 100 &&
        incoming().lastMessage is string &&
        incoming().lastMessage.size() > 0 &&
        incoming().lastMessage.size() <= 2000 &&
        incoming().keys().hasAll(['buyerEmail']) &&
        incoming().buyerEmail is string &&
        incoming().buyerEmail.size() <= 320
      );
    }

    function isValidChatMessage() {
      return (
        incoming() is map &&
        incoming().keys().hasAll(['senderId', 'senderRole', 'message']) &&
        incoming().senderId is string && incoming().senderId.size() <= 128 &&
        incoming().senderRole is string && incoming().senderRole.size() <= 50 &&
        incoming().message is string && incoming().message.size() <= 5000
      );
    }

    function isValidProduct() {
      return (
        incoming() is map &&
        incoming().keys().hasAll(['id', 'name', 'description', 'price', 'stock', 'imageUrl', 'category']) &&
        incoming().id is string && incoming().id.size() <= 128 &&
        incoming().name is string && incoming().name.size() <= 200 &&
        incoming().description is string && incoming().description.size() <= 2000 &&
        (incoming().price is int || incoming().price is float) && incoming().price >= 0 &&
        (incoming().stock is int || incoming().stock is float) && incoming().stock >= 0 && incoming().stock == math.floor(incoming().stock) &&
        incoming().imageUrl is string && incoming().imageUrl.size() <= 1000 &&
        incoming().category is string && incoming().category.size() <= 100
      );
    }

    function isValidReview() {
      return (
        incoming() is map &&
        incoming().keys().hasAll(['id', 'productId', 'userId', 'userName', 'rating', 'comment']) &&
        incoming().id is string && incoming().id.size() <= 128 &&
        incoming().productId is string && incoming().productId.size() <= 128 &&
        incoming().userId is string && incoming().userId.size() <= 128 &&
        incoming().userName is string && incoming().userName.size() <= 100 &&
        (incoming().rating is int || incoming().rating is float) && incoming().rating >= 1 && incoming().rating <= 5 &&
        incoming().comment is string && incoming().comment.size() <= 1000
      );
    }

    function isValidNotification() {
      return (
        incoming() is map &&
        incoming().keys().hasAll(['id', 'userId', 'title', 'body', 'read']) &&
        incoming().id is string && incoming().id.size() <= 128 &&
        incoming().userId is string && incoming().userId.size() <= 128 &&
        incoming().title is string && incoming().title.size() <= 200 &&
        incoming().body is string && incoming().body.size() <= 2000 &&
        incoming().read is bool
      );
    }

    // ════════════════════════════════════════════════════════════
    // GLOBAL SAFETY NET — Semua path harus didefinisikan eksplisit
    // ════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }

    // ════════════════════════════════════════════════════════════
    // ERP COLLECTIONS — Hanya untuk aplikasi ERP
    // ════════════════════════════════════════════════════════════

    // Web Store Config — baca/tulis hanya oleh ERP (authenticated)
    match /webstore_config/{cabangId} {
      allow get, list: if isAuthenticated();
      allow create, update, delete: if isOwnerOrAdmin();
    }

    // Products — ERP publish, Web Store baca
    match /products/{productId} {
      allow get, list: if true;  // Public read — Web Store customer bisa lihat produk
      allow create: if (isMerchant() || isOwnerOrAdmin()) && isValidProduct();
      allow update: if (isMerchant() || isOwnerOrAdmin()) && isValidProduct();
      allow delete: if isMerchant() || isOwnerOrAdmin();

      // Reviews subcollection — Customer bisa review produk
      match /reviews/{reviewId} {
        allow get, list: if true;
        allow create: if isAuthenticated() && incoming().userId == request.auth.uid && isValidReview();
        allow update: if isAuthenticated() && existing().userId == request.auth.uid;
        allow delete: if isMerchant() || (isAuthenticated() && existing().userId == request.auth.uid);
      }
    }

    // Categories — ERP atur, Web Store baca
    // Catatan: untuk list oleh non-authenticated, resource.data tidak tersedia
    match /categories/{cabangId} {
      allow get: if true;  // Public read — Web Store customer lihat kategori
      allow list: if true;  // Public list — diizinkan
      allow create, update, delete: if isOwnerOrAdmin();
    }

    // ERP Data (erp_*) — hanya ERP
    match /erp_bahan_baku/{docId} {
      allow get, list: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    match /erp_products/{docId} {
      allow get, list: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    match /erp_detail_resep/{docId} {
      allow get, list: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    match /erp_cabang/{docId} {
      allow get, list: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    match /erp_surat_orders/{docId} {
      allow get, list: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    match /erp_waste_logs/{docId} {
      allow get, list: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    match /erp_writeoff_logs/{docId} {
      allow get, list: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    match /erp_rd_experiments/{docId} {
      allow get, list: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    match /erp_toppings/{docId} {
      allow get, list: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    match /erp_cabang_stok/{docId} {
      allow get, list: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    match /erp_branch_transactions/{docId} {
      allow get, list: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    // ERP Notifications
    match /erp_notifications/{notifId} {
      allow get, list: if isAuthenticated();
      allow update: if isAuthenticated();
      allow create: if true;  // Web Store bisa kirim notifikasi
      allow delete: if isOwnerOrAdmin();
    }

    // Cabang Subdomains
    match /cabang_subdomains/{subdomain} {
      allow get, list: if isAuthenticated();
      allow create, update, delete: if isOwnerOrAdmin();
    }

    // ════════════════════════════════════════════════════════════
    // WEB STORE COLLECTIONS — dibedakan read vs write
    // ════════════════════════════════════════════════════════════

    // Orders — Customer bisa create, ERP & merchant bisa read + update
    match /orders/{orderId} {
      allow get: if isMerchant() || (isAuthenticated() && existing().userId == request.auth.uid);
      allow list: if isMerchant();  // Hanya merchant bisa list semua orders
      allow create: if isAuthenticated() && incoming().userId == request.auth.uid && isValidOrder();
      allow update: if isMerchant() || (isAuthenticated() && existing().userId == request.auth.uid);
      allow delete: if false;  // Tidak ada yang bisa hapus order
    }

    // User orders subcollection — setiap user bisa list order mereka sendiri
    match /user_orders/{userId}/orders/{orderId} {
      allow read, write: if isAuthenticated() && userId == request.auth.uid;
    }

    // Chats — Customer buat, ERP & merchant baca + balas
    // ERP menggunakan Anonymous Auth (signInAnonymously) sehingga:
    //   - isMerchant() ❌ (tidak punya email)
    //   - isOwnerOrAdmin() ✅ (hanya cek request.auth != null)
    //   - Butuh allow list: isOwnerOrAdmin() agar ERP bisa lihat SEMUA chat room
    match /chats/{chatId} {
      allow get: if isOwnerOrAdmin() || isMerchant() || (isAuthenticated() && chatId == request.auth.uid + '_admin');
      allow list: if isOwnerOrAdmin() || isMerchant() || (isAuthenticated() && existing().buyerId == request.auth.uid);
      allow create: if isAuthenticated() && isValidChat();
      allow update: if isOwnerOrAdmin() || isMerchant() || (isAuthenticated() && chatId == request.auth.uid + '_admin');
      allow delete: if false;

      // ⚠️ Messages (subcollection) — Chat messages
      //    isOwnerOrAdmin() di READ (get,list) = OK — ERP perlu baca semua pesan
      //    isOwnerOrAdmin() di CREATE = ❌ TIDAK — hanya isMerchant() yang boleh kirim
      //    (mencegah spam: anonymous user Web Store tidak bisa kirim pesan ke room orang lain)
      match /messages/{messageId} {
        allow get, list: if isOwnerOrAdmin() || isMerchant() || (isAuthenticated() && chatId == request.auth.uid + '_admin');
        allow create: if (isMerchant() || (isAuthenticated() && chatId == request.auth.uid + '_admin')) && isValidChatMessage();
        allow update, delete: if isMerchant();
      }
    }

    // Web Store Notifications — User-specific notifications
    // Catatan: untuk list oleh non-authenticated, resource.data tidak tersedia
    match /notifications/{notificationId} {
      allow get: if isAuthenticated() && existing().userId == request.auth.uid;
      allow list: if isAuthenticated();  // List diizinkan untuk authenticated, filter via query
      allow create: if isMerchant() || (isAuthenticated() && incoming().userId == request.auth.uid && isValidNotification());
      allow update, delete: if isAuthenticated() && existing().userId == request.auth.uid;
    }

    // Merchant Profiles — Self-enrollment
    match /merchants/{merchantId} {
      allow read, write: if isAuthenticated() && request.auth.uid == merchantId;
    }

    // ════════════════════════════════════════════════════════════
    // FALLBACK — path yang tidak tercakup di atas
    // ════════════════════════════════════════════════════════════
    // Tidak ada wildcard {document=**} — setiap path harus didefinisikan
    // Jika ada collection baru, tambahkan aturan spesifik di atas.
    // JANGAN tambahkan wildcard — demi keamanan.
    // Global safety net di atas akan menolak semua akses ke path yang tidak tercakup.
  }
}
